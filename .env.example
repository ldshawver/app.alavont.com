# ═══════════════════════════════════════════════════════════
#  Alavont Therapeutics — Self-Hosting Environment Variables
#  Copy this file to .env and fill in every value.
#  NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string.
# If using the bundled Postgres container leave this as-is.
DATABASE_URL=postgresql://alavont:CHANGE_ME_DB_PASSWORD@db:5432/alavont

# ── Clerk Authentication ────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=paste_your_clerk_secret_key_here
VITE_CLERK_PUBLISHABLE_KEY=paste_your_clerk_publishable_key_here
# Clerk Webhooks → Signing Secret (Clerk Dashboard → Webhooks → your endpoint)
CLERK_WEBHOOK_SECRET=whsec_paste_your_signing_secret_here

# ── Session ─────────────────────────────────────────────────
# Long random string — run: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# ── OpenAI (AI Concierge) ───────────────────────────────────
OPENAI_API_KEY=paste_your_openai_api_key_here

# ── Stripe (Payments) ───────────────────────────────────────
# Get these from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=paste_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=paste_your_stripe_publishable_key_here

# ── Twilio (SMS Notifications) ──────────────────────────────
TWILIO_ACCOUNT_SID=paste_your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=paste_your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── WooCommerce (Lucifer Cruz menu tab — optional) ──────────
# Set this URL to activate the LC WooCommerce store tab
VITE_WOOCOMMERCE_URL=

# ── Internal ────────────────────────────────────────────────
POSTGRES_DB=alavont
POSTGRES_USER=alavont
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
NODE_ENV=production
LOG_LEVEL=info
