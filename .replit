modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow]]
name = "lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm lint"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
SMTP_FROM = "no-reply@alavont.com"
SMTP_USER = "luke@adiken.com"
SMTP_HOST = "smtp.office365.com"
SMTP_PORT = "587"
SMTP_TLS = "true"
RECEIPT_PRINTER_URI = "ipp://100.83.99.2:631/printers/receipt"
RECEIPT_PRINTER_NAME = "receipt"
PRINT_SERVER_HOST = "100.83.99.2"
PRINT_SERVER_PORT = "631"

[[ports]]
localPort = 8080
externalPort = 80
