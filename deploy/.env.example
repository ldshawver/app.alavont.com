# ═══════════════════════════════════════════════════════════
#  Alavont Therapeutics — Self-Hosting Environment Variables
#  Copy this file to .env and fill in every value.
#  NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string.
# If using the bundled Postgres container leave this as-is.
DATABASE_URL=postgresql://alavont:CHANGE_ME_DB_PASSWORD@db:5432/alavont

# ── Clerk Authentication ────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Session ─────────────────────────────────────────────────
# Long random string — run: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# ── OpenAI (AI Concierge) ───────────────────────────────────
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Stripe (Payments) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Twilio (SMS Notifications) ──────────────────────────────
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── WooCommerce (Lucifer Cruz menu tab — optional) ──────────
# Set this URL to activate the LC WooCommerce store tab
VITE_WOOCOMMERCE_URL=

# ── Internal ────────────────────────────────────────────────
POSTGRES_DB=alavont
POSTGRES_USER=alavont
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
NODE_ENV=production
LOG_LEVEL=info
